APP_NAME=safety-control-backend

# Local PostgreSQL connection. The shared docker-compose.yml uses these values.
DATABASE_URL=postgresql://safety_control:safety_control_local@localhost:5432/safety_control_local
DATABASE_CONNECTION_TIMEOUT_MS=2000
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_POOL_MAX=5

# Comma-separated full emails, for example admin@example.com,ops@example.com
ADMIN_ALLOWED_EMAILS=
ADMIN_SCHEDULE_SUPERVISOR_EMAILS=
ADMIN_QR_MANAGER_EMAILS=

# Alternative to ADMIN_ALLOWED_EMAILS. Use example.com, not @example.com.
ADMIN_ALLOWED_DOMAIN=

# Firebase Admin credential path. Leave empty to return 503 for admin login until configured.
GOOGLE_APPLICATION_CREDENTIALS=

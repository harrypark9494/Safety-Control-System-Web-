rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/adminUsers/$(request.auth.uid));
    }

    function isOwner(workerId) {
      return signedIn() && request.auth.uid == workerId;
    }

    function isAllowedPayrollFile() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    match /payroll/{workerId}/{fileName} {
      allow read: if isOwner(workerId) || isAdmin();
      allow create, update: if isOwner(workerId) && isAllowedPayrollFile();
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

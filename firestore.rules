rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isOwner(workerId) {
      return signedIn() && request.auth.uid == workerId;
    }

    match /adminUsers/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /workers/{workerId} {
      allow read: if isOwner(workerId) || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /payrollDocuments/{workerId} {
      allow read: if isOwner(workerId) || isAdmin();
      allow create, update: if isOwner(workerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /workTypes/{workTypeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
